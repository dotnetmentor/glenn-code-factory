# ─────────────────────────────────────────────────────────────────────────────
# Backend (.NET API) configuration. `npm run dev` loads this into the dotnet
# process via dotenv-cli (see root package.json). Copy this file to `.env` and
# fill in the values. `.env` is gitignored; this `.env.example` is the committed
# reference and must never contain real secrets.
#
# Naming: ASP.NET maps `Section__Key` (double underscore) to config "Section:Key".
# The same keys are what you set as environment variables on Render in production.
# ─────────────────────────────────────────────────────────────────────────────

# Environment ("Development" locally; Render sets "Production").
ASPNETCORE_ENVIRONMENT=Development

# Postgres. The local docker DB (`npm run db:up`) listens on 43594 with trust auth.
# In production set this to your Render/Supabase connection string — a postgres://
# URI is auto-normalized to Npgsql keyword form and TLS is enabled automatically.
DATABASE_URL=Host=localhost;Port=43594;Database=app;Username=postgres

# REQUIRED at boot — the API refuses to start if blank. Generate: openssl rand -base64 32
# BACK UP the production value: losing it makes every DB-encrypted secret unrecoverable.
SystemSettings__EncryptionKey=

# JWT signing key, min 32 chars. Generate: openssl rand -base64 48
Jwt__Key=

# Bootstrap SuperAdmin, seeded on every boot (self-registration is closed).
# REQUIRED for first login — the API skips admin seeding if this is blank.
Bootstrap__SuperAdminEmail=admin@example.com

# ── File storage ── Provider: Local (disk) for dev, R2 (Cloudflare) for production.
FileStorage__Provider=Local
FileStorage__LocalPath=uploads
FileStorage__R2__AccountId=
FileStorage__R2__AccessKey=
FileStorage__R2__SecretKey=
FileStorage__R2__BucketName=
FileStorage__R2__PublicUrl=

# ── Email ── Provider: Console (logs the login OTP to the API console) for dev,
# Resend for production. With Console you don't need a Resend account to log in locally.
Email__Provider=Console
Email__Resend__ApiToken=
Email__Resend__FromEmail=

# ── Frontend (backoffice-web) ── Mapbox public token for the map skill. Optional.
# Create packages/backoffice-web/.env.local with this key (Vite loads VITE_* automatically).
# VITE_MAPBOX_TOKEN=

# ── Runtime daemons ──
# npm run dev starts a Cloudflare quick tunnel and sets Runtime__PublicApiUrl
# automatically (overrides System Settings + .env). Respawn Fly runtimes when
# the URL changes. Optional manual override:
# Runtime__PublicApiUrl=https://your-stable-host.example.com
